---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config.js";

const reader = createReader(process.cwd(), keystaticConfig);
const rawProjects = await reader.collections.projects.all();
const projects = rawProjects
  .map((p) => p.entry)
  .sort((a, b) => (a.order || 0) - (b.order || 0));

const rawSkills = await reader.collections.skills.all();
const skills = rawSkills
  .map((s) => s.entry)
  .sort((a, b) => (a.order || 0) - (b.order || 0));

const aboutData = await reader.singletons.about.read();

const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/project/**/*.{jpeg,jpg,png,gif,webp}",
);
---

<Layout>
  <section class="hero">
    <div class="middletext">
      <h1>Hey, It's <span class="hand">Mihir</span></h1>
    </div>
    <p class="herosub">
      Looking <span class="hand">empty</span>? Move the <span class="hand"
        >cursor</span
      >
    </p>
  </section>

  <section class="projectlist" id="projects">
    <h2>Featured <span class="hand">Projects</span></h2>

    {
      projects.map((project, index) => {
        const imagePath = project.image
          ? project.image.replace("../../", "../")
          : null;

        return (
          <a href={project.link || "#"} target="_blank">
            <div class="project" data-color={project.color || "#f0f2f7"}>
              {imagePath && projectImages[imagePath] ? (
                <Image
                  src={projectImages[imagePath]()}
                  alt={`${project.title} Preview`}
                  class="swipeimage"
                />
              ) : null}

              <div class="projectinfo">
                <p class="project-num">0{index + 1}</p>
                <div class="project-title-group">
                  <h3>{project.title}</h3>
                  <p class="project-desc">{project.description}</p>
                </div>
                <p class="project-cat">{project.category}</p>
              </div>
            </div>
          </a>
        );
      })
    }
  </section>

  <section class="skills" id="skills">
    <h2>My <span class="hand">Skills</span></h2>

    {
      skills.map((skillGroup, index) => (
        <div class="skill-row">
          <div class="skill-header">
            <p class="skill-num">0{index + 1}</p>
            <p class="skill-title">{skillGroup.title}</p>
            <p class="skill-preview">{skillGroup.preview}</p>
            <p class="skill-arrow">+</p>
          </div>
          <div class="skill-body">
            <div class="skill-inner">
              {skillGroup.tags.map((tag) => (
                <p class={tag.highlight ? "tag highlight" : "tag"}>
                  {tag.name}
                </p>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </section>

  <section class="about" id="about">
    <h2>About <span class="hand">Mihir</span></h2>

    <p class="about-text">
      {
        aboutData?.text ||
          "Hello! I am a developer. Go into the Keystatic Admin panel to edit this text!"
      }
    </p>
  </section>

  <section class="connect" id="connect">
    <div class="connect-header">
      <a href="mailto:hello@itsmihir.me" class="connect-title"
        >Let's Connect <span class="connect-arrow">↗</span></a
      >
    </div>
    <div class="connect-footer">
      <div class="footer-col">
        <p class="footer-label">Socials</p>
        <a href="https://github.com/m141r" target="_blank" class="footer-link"
          >GitHub</a
        >
        <a
          href="https://www.linkedin.com/in/mihirkumar027"
          target="_blank"
          class="footer-link">LinkedIn</a
        >
      </div>
      <div class="footer-col">
        <p class="footer-label">Resources</p>
        <a href="#" class="footer-link">Resume</a>
      </div>
      <div class="footer-col">
        <p class="footer-label">Status</p>
        <p class="footer-status">Available for projects</p>
      </div>
    </div>
  </section>
</Layout>

<script src="../scripts/hero-trail.js"></script>
<script src="../scripts/project-cursor.js"></script>
<script src="../scripts/gsap-skill.js"></script>
<script src="../scripts/about-text.js"></script>
<script src="../scripts/navbar-scramble.js"></script>
<script src="../scripts/entrance.js"></script>
<script src="../scripts/magnetic.js"></script>
<script src="../scripts/smooth-scroll.js"></script>
