---
import "../styles/index.css";
import Navbar from "../components/navbar.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/logo16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo32.png" />
    <title>Mihir Kumar — Portfolio</title>
    <meta
      name="description"
      content="Portfolio of Mihir Kumar — web developer focused on building fast, thoughtful products with Python, Flask, and modern frontend tools."
    />

    <meta property="og:title" content="Mihir Kumar — Developer" />
    <meta
      property="og:description"
      content="Portfolio of Mihir Kumar — web developer focused on building fast, thoughtful products with Python, Flask, and modern frontend tools."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://itsmihir.me/" />
    <meta property="og:image" content="https://itsmihir.me/og.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Mihir Kumar — Portfolio" />
    <meta
      name="twitter:description"
      content="Portfolio of Mihir Kumar — web developer focused on building fast, thoughtful products with Python, Flask, and modern frontend tools."
    />
    <meta name="twitter:image" content="https://itsmihir.me/og.png" />
    <link rel="canonical" href="https://itsmihir.me/" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="custom-cursor"></div>
    <Navbar />
    <slot />
    <script>
      import "../scripts/global-cursor.js";
    </script>
  </body>
</html>
